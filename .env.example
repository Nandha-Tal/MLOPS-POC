# ── Kubernetes ────────────────────────────────────────────────────────────────
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=default
# Set to "true" to use in-cluster service account (when running inside K8s)
K8S_IN_CLUSTER=false

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
# Set to "true" to use the built-in metrics simulator instead of real Prometheus
USE_SIMULATOR=true

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=k8s-anomaly-detection

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
APP_ENV=development

# ── Agentic AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Alerting ─────────────────────────────────────────────────────────────────
# Slack webhook for alert notifications (optional)
SLACK_WEBHOOK_URL=
# PagerDuty integration key (optional)
PAGERDUTY_ROUTING_KEY=

# ── DVC Remote ────────────────────────────────────────────────────────────────
DVC_REMOTE_URL=s3://your-bucket/k8s-monitoring

# ── Kubeflow ──────────────────────────────────────────────────────────────────
KUBEFLOW_ENDPOINT=http://localhost:8080
KUBEFLOW_NAMESPACE=kubeflow
